---
import ContentLayout from '../layouts/ContentLayout.astro';
import { render } from 'astro:content';
import { getEntryForLang } from '../lib/content';
import { type CollectionKey, type SiteLang } from '../lib/i18n';

interface Props {
  collection: CollectionKey;
  lang: SiteLang;
  baseSlug: string;
}

const { collection, lang, baseSlug } = Astro.props;
const result = await getEntryForLang(collection, lang, baseSlug);
if (!result) {
  throw new Error(`Missing ${collection}/${baseSlug} for language ${lang}`);
}
const { entry, languageLinks } = result;
const { Content, headings } = await render(entry);
const currentPath = `/${collection}/${baseSlug}/`;
---
<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  collectionLabel={entry.data.section}
  sourceUrl={entry.data.sourceUrl}
  sourcePath={entry.data.sourcePath}
  syncedAt={entry.data.syncedAt}
  headings={headings}
  lang={lang}
  currentPath={currentPath}
  languageLinks={languageLinks}
>
  <Content />
</ContentLayout>
