---
import ContentLayout from '../layouts/ContentLayout.astro';
import { render } from 'astro:content';
import { getEntryForLang } from '../lib/content';
import { buildEntryRoute, type CollectionKey, type SiteLang } from '../lib/i18n';

interface Props {
  collection: CollectionKey;
  lang: SiteLang;
  baseSlug: string;
}

const { collection, lang, baseSlug } = Astro.props;
const result = await getEntryForLang(collection, lang, baseSlug);
if (!result) {
  throw new Error(`Missing ${collection}/${baseSlug} for language ${lang}`);
}
const { entry, languageLinks, collectionEntries, previousEntry, nextEntry, summary } = result;
const { Content, headings } = await render(entry);
const currentPath = `/${collection}/${baseSlug}/`;
const collectionItems = collectionEntries.map((item) => ({
  title: item.data.title,
  href: buildEntryRoute(collection, item),
  active: item.data.baseSlug === baseSlug
}));
const previousLink = previousEntry
  ? { title: previousEntry.data.title, href: buildEntryRoute(collection, previousEntry) }
  : null;
const nextLink = nextEntry
  ? { title: nextEntry.data.title, href: buildEntryRoute(collection, nextEntry) }
  : null;
---
<ContentLayout
  title={entry.data.title}
  description={summary ?? entry.data.description}
  collectionLabel={entry.data.section}
  collection={collection}
  sourceUrl={entry.data.sourceUrl}
  sourcePath={entry.data.sourcePath}
  syncedAt={entry.data.syncedAt}
  headings={headings}
  lang={lang}
  currentPath={currentPath}
  languageLinks={languageLinks}
  collectionItems={collectionItems}
  previousLink={previousLink}
  nextLink={nextLink}
>
  <Content />
</ContentLayout>
