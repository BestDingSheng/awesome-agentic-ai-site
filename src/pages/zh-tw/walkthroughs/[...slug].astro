---
import EntryPage from '../../_EntryPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('walkthroughs');
  return entries
    .filter((entry) => entry.data.language === 'zh-tw')
    .map((entry) => ({ params: { slug: entry.data.baseSlug }, props: { baseSlug: entry.data.baseSlug } }));
}

const { baseSlug } = Astro.props;
---
<EntryPage collection="walkthroughs" lang="zh-tw" baseSlug={baseSlug} />
