---
import BaseLayout from '../layouts/BaseLayout.astro';
import manifest from '../data/sync-manifest.json';
---
<BaseLayout title="Updates · Awesome Agentic AI 中文学习站">
  <section class="panel">
    <span class="eyebrow">Sync Status</span>
    <h1>内容同步状态</h1>
    <p class="muted">这个页面用于展示当前网站内容来自哪个仓库、哪个提交，以及最近一次同步时间。</p>
    <ul>
      <li><strong>来源仓库：</strong><a href={manifest.repoUrl} target="_blank" rel="noreferrer">{manifest.repoUrl}</a></li>
      <li><strong>分支：</strong>{manifest.repoRef}</li>
      <li><strong>提交：</strong>{manifest.repoCommit}</li>
      <li><strong>同步时间：</strong>{manifest.syncedAt}</li>
    </ul>
  </section>

  <section class="panel" style="margin-top: 1.5rem;">
    <h2>内容计数</h2>
    <ul>
      <li>Stages：{manifest.counts.stages}</li>
      <li>Tracks：{manifest.counts.tracks}</li>
      <li>Branches：{manifest.counts.branches}</li>
      <li>Resources：{manifest.counts.resources}</li>
      <li>Walkthroughs：{manifest.counts.walkthroughs}</li>
    </ul>
  </section>
</BaseLayout>
