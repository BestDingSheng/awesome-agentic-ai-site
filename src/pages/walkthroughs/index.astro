---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionGrid from '../../components/CollectionGrid.astro';
import { getCollection } from 'astro:content';
const walkthroughs = await getCollection('walkthroughs');
const items = walkthroughs.map((entry) => ({
  title: entry.data.title,
  href: `/walkthroughs/${entry.slug}/`,
  description: entry.data.description,
  meta: entry.data.section
}));
---
<BaseLayout title="Walkthroughs · Awesome Agentic AI 中文学习站">
  <section class="section-head"><div><h1>Walkthroughs</h1><p class="muted">跨阶段实践示例与操作指南。</p></div></section>
  <CollectionGrid items={items} />
</BaseLayout>
