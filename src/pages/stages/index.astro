---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionGrid from '../../components/CollectionGrid.astro';
import { getCollection } from 'astro:content';
const stages = (await getCollection('stages')).sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const items = stages.map((entry) => ({
  title: entry.data.title,
  href: `/stages/${entry.slug}/`,
  description: entry.data.description,
  meta: `Stage ${entry.data.order ?? '-'} · ${entry.data.section}`
}));
---
<BaseLayout title="Stages · Awesome Agentic AI 中文学习站">
  <section class="section-head"><div><h1>Stages</h1><p class="muted">主学习阶段内容。</p></div></section>
  <CollectionGrid items={items} />
</BaseLayout>
