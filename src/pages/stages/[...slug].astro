---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('stages');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---
<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  collectionLabel={entry.data.section}
  sourceUrl={entry.data.sourceUrl}
  sourcePath={entry.data.sourcePath}
  syncedAt={entry.data.syncedAt}
  headings={headings}
>
  <Content />
</ContentLayout>
