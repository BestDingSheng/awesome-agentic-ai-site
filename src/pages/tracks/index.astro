---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionGrid from '../../components/CollectionGrid.astro';
import { getCollection } from 'astro:content';
const tracks = await getCollection('tracks');
const items = tracks.map((entry) => ({
  title: entry.data.title,
  href: `/tracks/${entry.slug}/`,
  description: entry.data.description,
  meta: entry.data.section
}));
---
<BaseLayout title="Tracks · Awesome Agentic AI 中文学习站">
  <section class="section-head"><div><h1>Tracks</h1><p class="muted">按照学习目标划分的路线。</p></div></section>
  <CollectionGrid items={items} />
</BaseLayout>
