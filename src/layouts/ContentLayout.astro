---
import BaseLayout from './BaseLayout.astro';
import { buildLangPath, type SiteLang } from '../lib/i18n';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  collectionLabel: string;
  sourceUrl: string;
  sourcePath: string;
  syncedAt: string;
  headings?: Heading[];
  lang: SiteLang;
  currentPath: string;
  languageLinks: Array<{ lang: SiteLang; label: string; href: string }>;
}

const { title, description, collectionLabel, sourceUrl, sourcePath, syncedAt, headings = [], lang, currentPath, languageLinks } = Astro.props;
const docHeadings = headings.filter((item) => item.depth >= 2 && item.depth <= 4);
const syncedText = new Date(syncedAt).toLocaleString('zh-CN', { hour12: false });
---
<BaseLayout
  title={`${title} · Awesome Agentic AI 学习站`}
  description={description}
  lang={lang}
  currentPath={currentPath}
  languageLinks={languageLinks}
>
  <div class="section" style="margin-top: 0;">
    <div class="section-head" style="margin-bottom: 1.2rem; align-items: start;">
      <div>
        <p class="section-kicker">Documentation</p>
        <div class="doc-breadcrumb small muted">
          <a href={buildLangPath(lang, '/')}>Home</a>
          <span>/</span>
          <span>{collectionLabel}</span>
        </div>
        <h1 class="doc-title" style="font-size: clamp(2rem, 3vw, 3rem); margin-top: 0.55rem;">{title}</h1>
        {description && <p class="hero-lead" style="margin-top: 0.75rem; max-width: 52rem;">{description}</p>}
      </div>
    </div>

    <section class="doc">
      <aside class="sidebar-panel surface">
        <span class="badge">{collectionLabel}</span>
        <div class="meta-list" style="margin-top: 1rem;">
          <div class="doc-meta-item" style="padding: 0.9rem 1rem;">
            <div class="small muted">语言版本</div>
            <div class="small"><strong>{languageLinks.find((item) => item.lang === lang)?.label ?? lang}</strong></div>
          </div>
          <div class="doc-meta-item" style="padding: 0.9rem 1rem;">
            <div class="small muted">同步时间</div>
            <div class="small"><strong>{syncedText}</strong></div>
          </div>
          <div class="doc-meta-item" style="padding: 0.9rem 1rem;">
            <div class="small muted">源文件</div>
            <div class="small" style="word-break: break-word;">{sourcePath}</div>
          </div>
        </div>

        <div class="mini-list" style="margin-top: 1rem;">
          <a class="button" href={sourceUrl} target="_blank" rel="noreferrer">查看原仓库</a>
        </div>
      </aside>

      <article class="markdown">
        <slot />
      </article>

      <aside class="toc surface">
        <div class="toc-title">On this page</div>
        {docHeadings.length > 0 ? (
          <ul>
            {docHeadings.map((heading) => (
              <li>
                <a class:list={[`depth-${heading.depth}`]} href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty-note">该页面暂时没有可展示的目录标题。</p>
        )}
      </aside>
    </section>
  </div>
</BaseLayout>
