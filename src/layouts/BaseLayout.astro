---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { LANG_CONFIG, buildLangPath, createSectionLanguageLinks, type SiteLang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: SiteLang;
  currentPath?: string;
  languageLinks?: Array<{ lang: SiteLang; label: string; href: string }>;
  image?: string;
  noindex?: boolean;
}
const SITE_URL = 'https://awesome-agentic-ai-site.vercel.app';
const DEFAULT_SOCIAL_IMAGE = '/favicon.svg';
const {
  title = 'Awesome Agentic AI 学习站',
  description = '基于 awesome-agentic-ai-zh 构建的 Astro 学习地图网站。',
  lang = 'zh-cn',
  currentPath = '/',
  languageLinks = createSectionLanguageLinks(currentPath),
  image = DEFAULT_SOCIAL_IMAGE,
  noindex = false
} = Astro.props;

const canonicalUrl = new URL(buildLangPath(lang, currentPath), SITE_URL).toString();
const socialImageUrl = new URL(image, SITE_URL).toString();
const alternateLinks = languageLinks.map((link) => ({
  ...link,
  absoluteHref: new URL(link.href, SITE_URL).toString(),
  htmlLang: LANG_CONFIG[link.lang].htmlLang
}));
const xDefaultHref = new URL(buildLangPath('zh-cn', currentPath), SITE_URL).toString();

const navItems = [
  { label: '首页', path: '/' },
  { label: '搜索', path: '/search/' },
  { label: '路线图', path: '/roadmap/' },
  { label: 'Stages', path: '/stages/' },
  { label: 'Tracks', path: '/tracks/' },
  { label: 'Branches', path: '/branches/' },
  { label: 'Resources', path: '/resources/' },
  { label: 'Updates', path: '/updates/' }
].map((item) => ({ ...item, href: buildLangPath(lang, item.path) }));
---
<!doctype html>
<html lang={LANG_CONFIG[lang].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((link) => <link rel="alternate" hreflang={link.htmlLang} href={link.absoluteHref} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Awesome Agentic AI 学习站" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={LANG_CONFIG[lang].htmlLang} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-bg" aria-hidden="true">
      <div class="aurora aurora-a"></div>
      <div class="aurora aurora-b"></div>
      <div class="grid-mask"></div>
    </div>

    <header class="site-header">
      <div class="shell header-inner">
        <div class="brand-block">
          <a class="brand" href={buildLangPath(lang, '/')}>
            <span class="brand-mark">AI</span>
            <span class="brand-text">
              <strong>Awesome Agentic AI</strong>
              <small>Learning Hub</small>
            </span>
          </a>
        </div>

        <div class="header-right">
          <nav class="nav" aria-label="Primary navigation">
            {navItems.map((item) => (
              <a class:list={["nav-link", currentPath === item.path && 'active']} href={item.href}>{item.label}</a>
            ))}
          </nav>
          <LanguageSwitcher currentLang={lang} links={languageLinks} />
        </div>
      </div>
    </header>

    <main class="shell site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <div>
          <p class="footer-title">Awesome Agentic AI 学习站</p>
          <p class="footer-copy">基于 fork 内容自动同步生成的多语言学习文档站，默认简体中文。</p>
        </div>
        <div class="footer-links">
          <a href={buildLangPath(lang, '/search/')}>搜索内容</a>
          <a href={buildLangPath(lang, '/updates/')}>同步状态</a>
          <a href="https://github.com/BestDingSheng/awesome-agentic-ai-site" target="_blank" rel="noreferrer">网站仓库</a>
          <a href="https://github.com/BestDingSheng/awesome-agentic-ai-zh" target="_blank" rel="noreferrer">内容仓库</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a1020;
    --bg-elevated: rgba(15, 23, 42, 0.78);
    --panel: rgba(13, 20, 37, 0.78);
    --panel-strong: rgba(16, 24, 44, 0.92);
    --panel-soft: rgba(148, 163, 184, 0.08);
    --line: rgba(148, 163, 184, 0.15);
    --line-strong: rgba(148, 163, 184, 0.24);
    --text: #ecf3ff;
    --text-soft: #c7d2e7;
    --muted: #93a4c3;
    --brand: #7c9cff;
    --brand-strong: #5b7cff;
    --brand-soft: rgba(124, 156, 255, 0.14);
    --success: #80e2b6;
    --max: 1240px;
    --radius-xl: 28px;
    --radius-lg: 22px;
    --radius-md: 16px;
    --shadow-lg: 0 18px 60px rgba(0, 0, 0, 0.28);
    --shadow-md: 0 10px 30px rgba(0, 0, 0, 0.18);
  }

  * { box-sizing: border-box; }
  html {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at top, rgba(91, 124, 255, 0.12), transparent 28%),
      radial-gradient(circle at 80% 20%, rgba(65, 211, 189, 0.09), transparent 26%),
      var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }
  body { margin: 0; min-height: 100vh; }
  a { color: var(--brand); text-decoration: none; }
  a:hover { text-decoration: none; }
  img { max-width: 100%; height: auto; }
  strong { color: var(--text); }
  .shell { width: min(var(--max), calc(100% - 2rem)); margin: 0 auto; }

  .site-bg {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: -1;
  }
  .aurora {
    position: absolute;
    border-radius: 999px;
    filter: blur(90px);
    opacity: 0.55;
  }
  .aurora-a {
    width: 28rem;
    height: 28rem;
    top: -8rem;
    left: -8rem;
    background: rgba(91, 124, 255, 0.18);
  }
  .aurora-b {
    width: 24rem;
    height: 24rem;
    right: -5rem;
    top: 8rem;
    background: rgba(54, 211, 153, 0.12);
  }
  .grid-mask {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.32), transparent 78%);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(18px);
    background: rgba(7, 12, 25, 0.72);
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 78px;
    padding: 0.9rem 0;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--text);
  }
  .brand:hover { text-decoration: none; }
  .brand-mark {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-grid;
    place-items: center;
    border-radius: 0.9rem;
    background: linear-gradient(135deg, rgba(124,156,255,0.95), rgba(79,110,255,0.95));
    color: white;
    font-size: 0.9rem;
    font-weight: 800;
    box-shadow: 0 8px 20px rgba(91, 124, 255, 0.25);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand-text strong { font-size: 0.98rem; font-weight: 800; }
  .brand-text small { color: var(--muted); font-size: 0.78rem; margin-top: 0.2rem; }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    padding: 0.35rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(148,163,184,0.12);
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.58rem 0.9rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
    transition: 160ms ease;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: rgba(124,156,255,0.14);
  }

  .site-main { padding: 2.2rem 0 4.5rem; }
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 2rem;
    padding: 1.8rem 0 3rem;
    color: var(--muted);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .footer-title {
    margin: 0 0 0.35rem;
    color: var(--text);
    font-weight: 700;
  }
  .footer-copy {
    margin: 0;
    max-width: 40rem;
    line-height: 1.7;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: flex-end;
  }
  .footer-links a {
    color: var(--muted);
  }
  .footer-links a:hover {
    color: var(--text);
  }

  h1, h2, h3 { line-height: 1.1; letter-spacing: -0.02em; margin: 0; }
  h1 { font-size: clamp(2.4rem, 4.8vw, 4.3rem); }
  h2 { font-size: clamp(1.45rem, 2vw, 2rem); }
  h3 { font-size: 1.08rem; }
  p, li { line-height: 1.75; }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(300px, 0.95fr);
    gap: 1.2rem;
    align-items: stretch;
  }
  .hero-card, .panel, .card, .surface {
    background: linear-gradient(180deg, rgba(19, 28, 49, 0.88), rgba(12, 19, 36, 0.9));
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .hero-card {
    padding: 1.6rem;
  }
  .hero-card.primary {
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero-card.primary::after {
    content: '';
    position: absolute;
    inset: auto -4rem -5rem auto;
    width: 16rem;
    height: 16rem;
    background: radial-gradient(circle, rgba(124,156,255,0.18), transparent 62%);
    pointer-events: none;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.8rem;
    border-radius: 999px;
    background: var(--brand-soft);
    color: #bfd0ff;
    font-size: 0.83rem;
    font-weight: 800;
    letter-spacing: 0.01em;
  }
  .hero-lead {
    margin: 1rem 0 0;
    max-width: 46rem;
    color: var(--text-soft);
    font-size: 1.06rem;
  }
  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 44px;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    color: var(--text);
    background: rgba(255,255,255,0.03);
    font-weight: 700;
    transition: 160ms ease;
  }
  .button:hover {
    transform: translateY(-1px);
    border-color: rgba(148, 163, 184, 0.28);
    background: rgba(255,255,255,0.05);
  }
  .button.primary {
    background: linear-gradient(135deg, var(--brand), var(--brand-strong));
    border-color: transparent;
    box-shadow: 0 12px 28px rgba(91, 124, 255, 0.28);
  }

  .hero-meta-list,
  .mini-list,
  .meta-list {
    display: grid;
    gap: 0.85rem;
  }
  .mini-item,
  .stat,
  .quick-card,
  .route-item,
  .doc-meta-item {
    border: 1px solid rgba(148, 163, 184, 0.12);
    background: rgba(255,255,255,0.03);
    border-radius: 16px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }
  .stat {
    padding: 1rem;
  }
  .stat span {
    display: block;
    color: var(--muted);
    font-size: 0.84rem;
  }
  .stat strong {
    display: block;
    margin-top: 0.25rem;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .section {
    margin-top: 2rem;
  }
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1rem;
  }
  .section-head p,
  .section-copy,
  .muted {
    color: var(--muted);
  }
  .section-kicker {
    margin: 0 0 0.5rem;
    color: #bfd0ff;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .section-link {
    color: var(--text-soft);
    font-weight: 700;
  }

  .grid { display: grid; gap: 1rem; }
  .grid.cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .grid.cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .card {
    padding: 1.2rem;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: rgba(124, 156, 255, 0.28);
    background: linear-gradient(180deg, rgba(24, 35, 60, 0.92), rgba(13, 20, 37, 0.92));
  }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.62rem;
    border-radius: 999px;
    background: rgba(128, 226, 182, 0.12);
    color: var(--success);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.01em;
  }
  .small { font-size: 0.92rem; }

  .doc {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr) 220px;
    gap: 1.25rem;
    align-items: start;
  }
  .sidebar-panel,
  .toc,
  .markdown {
    border-radius: var(--radius-lg);
  }
  .sidebar-panel,
  .toc {
    position: sticky;
    top: 100px;
    padding: 1.1rem;
  }
  .markdown {
    padding: 2rem;
    background: linear-gradient(180deg, rgba(12, 18, 33, 0.92), rgba(11, 17, 30, 0.96));
    border: 1px solid rgba(148, 163, 184, 0.1);
    box-shadow: var(--shadow-lg);
  }
  .markdown > :first-child { margin-top: 0; }
  .markdown h1,
  .markdown h2,
  .markdown h3,
  .markdown h4 { scroll-margin-top: 110px; }
  .markdown h2 {
    margin-top: 2.4rem;
    margin-bottom: 0.9rem;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(148,163,184,0.1);
  }
  .markdown h3 { margin-top: 1.7rem; margin-bottom: 0.7rem; }
  .markdown p,
  .markdown li {
    color: var(--text-soft);
    font-size: 1rem;
  }
  .markdown a {
    color: #b8c8ff;
    text-decoration: underline;
    text-decoration-color: rgba(184,200,255,0.35);
    text-underline-offset: 0.2em;
  }
  .markdown a:hover {
    text-decoration-color: rgba(184,200,255,0.75);
  }
  .markdown table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.15rem 0;
    overflow: hidden;
    border-radius: 14px;
  }
  .markdown th,
  .markdown td {
    border: 1px solid rgba(148,163,184,0.12);
    padding: 0.8rem;
    text-align: left;
    vertical-align: top;
  }
  .markdown th {
    background: rgba(255,255,255,0.04);
    color: var(--text);
  }
  .markdown code {
    background: rgba(255,255,255,0.07);
    padding: 0.15rem 0.38rem;
    border-radius: 0.45rem;
    font-size: 0.92em;
  }
  .markdown pre {
    padding: 1rem;
    overflow: auto;
    border-radius: 16px;
    background: #09101d;
    border: 1px solid rgba(148,163,184,0.1);
  }
  .markdown pre code {
    background: transparent;
    padding: 0;
  }
  .markdown blockquote {
    margin: 1.15rem 0;
    border-left: 3px solid var(--brand);
    padding: 0.65rem 1rem;
    color: var(--text-soft);
    background: rgba(124, 156, 255, 0.06);
    border-radius: 0 14px 14px 0;
  }

  .toc-title,
  .panel-title {
    margin-bottom: 0.9rem;
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--text);
  }
  .toc ul,
  .meta ul { list-style: none; margin: 0; padding: 0; }
  .toc li { margin: 0.35rem 0; }
  .toc a {
    display: block;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.45;
    padding-left: 0.2rem;
  }
  .toc a:hover { color: var(--text); }
  .toc .depth-3 { padding-left: 0.85rem; }
  .toc .depth-4 { padding-left: 1.4rem; }

  .route-list { display: grid; gap: 0.85rem; }
  .route-item {
    padding: 1rem 1.05rem;
  }

  .empty-note {
    color: var(--muted);
    font-size: 0.92rem;
  }

  @media (max-width: 1180px) {
    .doc { grid-template-columns: 260px minmax(0, 1fr); }
    .toc { display: none; }
  }
  @media (max-width: 960px) {
    .hero,
    .grid.cols-2,
    .grid.cols-3,
    .doc { grid-template-columns: 1fr; }
    .header-inner,
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .header-right { width: 100%; justify-content: flex-start; }
    .nav { border-radius: 18px; }
    .sidebar-panel,
    .toc { position: static; }
    .markdown { padding: 1.35rem; }
  }
  @media (max-width: 640px) {
    .shell { width: min(var(--max), calc(100% - 1rem)); }
    .hero-card,
    .hero-card.primary,
    .card,
    .panel,
    .sidebar-panel,
    .toc,
    .markdown { padding: 1rem; }
    .stats { grid-template-columns: 1fr 1fr; }
    .button-row { flex-direction: column; align-items: stretch; }
    .button { width: 100%; }
  }
</style>
