---
interface Item {
  title: string;
  href: string;
  description?: string;
  meta?: string;
  detail?: string;
  searchText?: string;
  category?: string;
}
interface Props {
  items: Item[];
  variant?: 'default' | 'feature';
}
const { items, variant = 'default' } = Astro.props;
---
<div class:list={["grid", variant === 'feature' ? 'cols-3' : 'cols-2']}>
  {items.map((item) => (
    <a
      class:list={["card", "collection-card", variant === 'feature' && 'feature-card']}
      href={item.href}
      data-search={item.searchText ?? `${item.title} ${item.description ?? ''} ${item.meta ?? ''} ${item.detail ?? ''}`}
      data-category={item.category ?? 'all'}
    >
      <div class="collection-card-top">
        <div class="badge">{item.meta ?? '内容'}</div>
        <span class="collection-arrow">→</span>
      </div>
      <h3>{item.title}</h3>
      {item.description && <p class="muted collection-desc">{item.description}</p>}
      {item.detail && <div class="collection-detail small">{item.detail}</div>}
    </a>
  ))}
</div>

<style>
  .collection-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 180px;
    color: var(--text);
  }
  .collection-card:hover {
    text-decoration: none;
  }
  .collection-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .collection-card h3 {
    font-size: 1.15rem;
    margin: 0;
  }
  .collection-desc {
    margin: 0;
  }
  .collection-detail {
    margin-top: auto;
    color: var(--text-soft);
    padding-top: .35rem;
    border-top: 1px solid rgba(148,163,184,0.1);
  }
  .collection-arrow {
    color: var(--muted);
    font-weight: 800;
    transition: transform 160ms ease, color 160ms ease;
  }
  .collection-card:hover .collection-arrow {
    transform: translateX(3px);
    color: var(--text);
  }
  .feature-card {
    min-height: 200px;
  }
</style>
