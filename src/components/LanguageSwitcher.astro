---
import type { SiteLang } from '../lib/i18n';

interface LinkItem {
  lang: SiteLang;
  label: string;
  href: string;
}

interface Props {
  currentLang: SiteLang;
  links: LinkItem[];
}

const { currentLang, links } = Astro.props;
---
<div class="lang-switcher" aria-label="Language switcher">
  {links.map((item) => (
    <a class:list={["lang-link", item.lang === currentLang && 'active']} href={item.href} hreflang={item.lang}>
      {item.label}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    flex-wrap: wrap;
    gap: .4rem;
    align-items: center;
    padding: .25rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(148,163,184,0.12);
  }
  .lang-link {
    display: inline-flex;
    align-items: center;
    padding: .5rem .78rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--muted);
    font-size: .88rem;
    font-weight: 800;
    text-decoration: none;
    transition: 160ms ease;
  }
  .lang-link:hover {
    color: var(--text);
    text-decoration: none;
    background: rgba(255,255,255,0.04);
  }
  .lang-link.active {
    background: rgba(124, 156, 255, 0.18);
    color: var(--text);
    border-color: rgba(124, 156, 255, 0.35);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
  }
</style>
